generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Product {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String
  price       Int
  stock       Int         @default(0)
  images      String[]
  weight      Float
  height      Int
  width       Int
  length      Int
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]

  @@index([slug])
  @@index([active])
}

model Order {
  id                  String         @id @default(cuid())
  customerName        String
  customerEmail       String
  customerPhone       String
  customerCpf         String
  paymentStatus       PaymentStatus  @default(PENDING)
  paymentMethod       String?
  infinitePayLink     String?
  infinitePayOrderNsu String         @unique
  infinitePaySlug     String?
  transactionNsu      String?
  receiptUrl          String?
  paidAt              DateTime?
  subtotal            Int
  shippingAmount      Int
  totalAmount         Int
  shippingStatus      ShippingStatus @default(PENDING)
  melhorEnvioId       String?
  trackingCode        String?
  shippedAt           DateTime?
  deliveredAt         DateTime?
  addressCep          String
  addressStreet       String
  addressNumber       String
  addressComplement   String?
  addressNeighborhood String
  addressCity         String
  addressState        String
  metaEventId         String         @default(cuid())
  emailSentAt         DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  items               OrderItem[]

  @@index([customerEmail])
  @@index([paymentStatus])
  @@index([shippingStatus])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Int

  @@index([orderId])
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ShippingStatus {
  PENDING
  LABEL_CREATED
  SHIPPED
  DELIVERED
  RETURNED
}
